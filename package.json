{
  "name": "gotea",
  "version": "1.0.0",
  "private": true,
  "description": "gotea front development tools configuration",
  "author": "Kazuki Kamizuru",
  "scripts": {
    "biome": "biome format ./resources/assets",
    "dev": "vite build --mode development --watch",
    "lint": "concurrently --success=all \"npm:lint:scripts\" \"npm:lint:styles\"",
    "lint:scripts": "npm run biome",
    "lint:styles": "stylelint \"./resources/assets/styles/**/*.scss\" \"./resources/assets/scripts/**/*.vue\"",
    "format": "concurrently --success=all \"npm:format:scripts\" \"npm:format:styles\"",
    "format:scripts": "npm run lint:scripts -- --write",
    "format:styles": "npm run lint:styles -- --fix",
    "test": "vitest",
    "build": "vite build"
  },
  "main": "resources/scripts/main.ts",
  "dependencies": {
    "axios": "^1.18.1",
    "dayjs": "^1.11.21",
    "vue": "^3.5.39",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "concurrently": "^10.0.3",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.16",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "sass": "^1.101.0",
    "stylelint": "^16.23.1",
    "stylelint-config-recommended-scss": "^16.0.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-scss": "^6.12.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-biome": "^1.2.0",
    "vite-plugin-stylelint": "^6.1.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=24.16 <25",
    "npm": ">=11"
  },
  "license": "MIT",
  "type": "module"
}
